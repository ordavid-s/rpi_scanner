[Unit]
Description=BT GPS Panel
After=network-online.target bluetooth.service gpsd.service hostapd.service dnsmasq.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/bt-gps-panel
EnvironmentFile=/opt/bt-gps-panel/config.env
ExecStart=/opt/bt-gps-panel/.venv/bin/uvicorn app.main:app --host ${APP_HOST} --port ${APP_PORT} --ssl-certfile ${CERT_FILE} --ssl-keyfile ${KEY_FILE}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
